{
  "layer": "top",
  "position": "top",
  "output": [
    "DP-3"
  ],
  "modules-center": [],
  "modules-right": [
    "clock#us",
    "clock#ptg",
    "clock"
  ],
  "include": [
    "~/.config/dotfiles/omarchy/waybar/base-bar.jsonc"
  ],
  "clock#us": {
    "format": "{:L%H:%M %a %d NY} ",
    "tooltip": false,
    "timezone": "America/New_York"
  },
  "clock#ptg": {
    "format": "{:L%H:%M %a %d PT} ",
    "tooltip": false,
    "timezone": "Portugal"
  }
}
