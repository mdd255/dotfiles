{
  "layer": "bottom",
  "position": "top",
  "output": [
    "eDP-1"
  ],
  "modules-center": [],
  "modules-right": [
    "custom/events"
  ],
  "include": [
    "~/.config/dotfiles/omarchy/waybar/base-bar.jsonc"
  ],
  "custom/events": {
    "format-icons": {
      "default": ""
    },
    "tooltip": true,
    "interval": 60,
    "exec": "~/.config/dotfiles/omarchy/scripts/khal-custom",
    "on-click": "~/.config/dotfiles/omarchy/scripts/khal-notify",
    "return-type": "json"
  }
}
